{
  "name": "AI as Lib Workshop",
  // Pre-built image from OVH registry (multi-arch: amd64 + arm64)
  // To fallback to local Dockerfile build, replace "image" with:
  //   "build": { "dockerfile": "Dockerfile" }
  "image": "ubf2r2if.c1.gra9.container-registry.ovh.net/lab/ai-as-lib-workshop-devcontainer:1.0.0",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "vscjava.vscode-java-pack@0.30.5",
        "redhat.java@1.51.0",
        "jbangdev.jbang-vscode@0.12.0",
        "bierner.markdown-mermaid@1.32.0",
        "-GitHub.copilot"
      ],
      "settings": {
				"java.configuration.runtimes": [
					{
						"name": "JavaSE-25",
						"path": "/home/vscode/.sdkman/candidates/java/current/"
					}
				],
				// disable github copilot chat panel
				"github.copilot.chat.enable": false,
				// disable chat panel
				"github.copilot.chat.showChatOnStartup": false
      }
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [8080, 5005, 7860],
  "portsAttributes": {
    "8080": {
      "label": "Quarkus Application",
      "onAutoForward": "notify"
    },
    "5005": {
      "label": "Java Debug",
      "onAutoForward": "silent"
    },
    "7860": {
      "label": "Gradio UI",
      "onAutoForward": "notify"
    }
  }
}
